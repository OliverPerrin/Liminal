# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_SESSION_MODEL=claude-sonnet-4-5
ANTHROPIC_API_VERSION=2023-06-01

# Supabase server env vars
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional explicit Next public aliases (auto-filled from SUPABASE_* by next.config.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional: explicit site URL for Stripe checkout redirects
# (falls back to the request Origin header, then http://localhost:3000)
NEXT_PUBLIC_SITE_URL=